{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tabula-share",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-19",
  "durable_objects": {
    "bindings": [
      {
        "name": "COLLABORATION_ROOMS",
        "class_name": "CollaborationRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CollaborationRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
